            <!-- ARSIP PANDANGAN: SUB-JENDELA DETAIL PRODUK DAN KOTAK ULASAN -->
            <div id="view-detail" class="tab-view hidden space-y-3 p-4">
                <button onclick="changeTab('home')" class="text-xs text-zinc-400 flex items-center gap-1 font-semibold hover:text-gold"><i data-lucide="arrow-left" class="w-3.5 h-3.5"></i> Kembali</button>
                <div id="product-detail-content" class="bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 p-4 rounded-xl space-y-3 shadow-sm"></div>
                
                <div class="bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 p-4 rounded-xl space-y-3 shadow-sm">
                    <div class="flex justify-between items-center border-b border-zinc-100 dark:border-zinc-900 pb-2">
