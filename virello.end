                    <div class="flex gap-3 text-zinc-400">
                        <i data-lucide="settings" class="w-5 h-5 cursor-pointer hover:text-gold transition-colors"></i>
                        <i data-lucide="message-square" class="w-5 h-5 cursor-pointer hover:text-gold transition-colors"></i>
                    </div>
