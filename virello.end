                        <div class="flex flex-col items-center gap-1 cursor-pointer hover:text-gold"><i data-lucide="wallet" class="w-5 h-5 opacity-80"></i><span>Belum Bayar</span></div>
                        <div class="flex flex-col items-center gap-1 cursor-pointer hover:text-gold"><i data-lucide="package" class="w-5 h-5 opacity-80"></i><span>Dikemas</span></div>
                        <div onclick="changeTab('tracking')" class="flex flex-col items-center gap-1 cursor-pointer text-gold font-bold"><i data-lucide="truck" class="w-5 h-5"></i><span>Dikirim</span></div>
                        <div class="flex flex-col items-center gap-1 cursor-pointer hover:text-gold"><i data-lucide="star" class="w-5 h-5 opacity-80"></i><span>Penilaian</span></div>
