<!DOCTYPE html>
<html lang="id" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Virello Marketplace - Signature Luxury Edition</title>
    
    <!-- PENGATURAN GAYA & FRAMEWORK EKSTERNAL -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // Konfigurasi Kustomisasi Tema Tailwind (Aksen Emas Eksklusif)
            tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        gold: {
                            light: '#efd5a5',
                            DEFAULT: '#dfba73',
                            dark: '#c29d56'
                        }
                    }
                }
            }
        }
    </script>
    
    <!-- Pustaka Ikon Lucide & Integrasi Font Google -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght=0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; transition: background-color 0.3s, color 0.3s; }
        .serif { font-family: 'Playfair Display', serif; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="max-w-md mx-auto min-h-screen shadow-2xl relative bg-zinc-50 text-zinc-900 dark:bg-[#030303] dark:text-zinc-100 border-x border-zinc-200 dark:border-zinc-900 pb-20 select-none">

    <!-- KOMPONEN: SIMULATOR NOTIFIKASI PUSH ANDROID -->
    <div id="android-push" class="fixed top-4 left-1/2 -translate-x-1/2 w-11/12 bg-white/95 dark:bg-zinc-900/95 border border-zinc-200 dark:border-zinc-800 text-zinc-900 dark:text-white rounded-2xl p-3.5 z-50 flex items-start gap-3 shadow-2xl transition-all duration-500 transform -translate-y-44 opacity-0 pointer-events-none">
        <div class="bg-gold p-2 rounded-xl text-black"><i data-lucide="bell" class="w-4 h-4"></i></div>
        <div class="flex-1">
            <div class="flex justify-between items-center"><span class="text-[10px] font-black uppercase tracking-wider text-gold-dark">Virello Gateway</span><span class="text-[9px] text-zinc-500">Just Now</span></div>
            <h4 id="push-title" class="text-xs font-bold mt-0.5">Notification</h4>
            <p id="push-desc" class="text-[11px] text-zinc-500 dark:text-zinc-400 mt-0.5 leading-snug"></p>
        </div>
    </div>

    <!-- KOMPONEN: JENDELA MODAL POPUP RATING & ULASAN -->
    <div id="review-modal" class="fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4 hidden max-w-md mx-auto">
        <div class="bg-white dark:bg-zinc-900 w-full p-5 rounded-2xl border border-zinc-200 dark:border-zinc-800 space-y-4 shadow-2xl">
            <div class="text-center">
                <h3 class="text-sm font-black uppercase tracking-wider text-zinc-800 dark:text-zinc-200">Berikan Ulasan Produk</h3>
                <p class="text-[10px] text-zinc-400 mt-0.5">Bagikan pengalaman Anda menggunakan produk ini</p>
            </div>
            <div class="flex justify-center gap-2 py-1">
                <button onclick="setReviewRating(1)" class="star-btn text-zinc-300 dark:text-zinc-700"><i data-lucide="star" class="w-6 h-6 fill-current"></i></button>
                <button onclick="setReviewRating(2)" class="star-btn text-zinc-300 dark:text-zinc-700"><i data-lucide="star" class="w-6 h-6 fill-current"></i></button>
                <button onclick="setReviewRating(3)" class="star-btn text-zinc-300 dark:text-zinc-700"><i data-lucide="star" class="w-6 h-6 fill-current"></i></button>
                <button onclick="setReviewRating(4)" class="star-btn text-zinc-300 dark:text-zinc-700"><i data-lucide="star" class="w-6 h-6 fill-current"></i></button>
                <button onclick="setReviewRating(5)" class="star-btn text-zinc-300 dark:text-zinc-700"><i data-lucide="star" class="w-6 h-6 fill-current"></i></button>
            </div>
            <div class="space-y-1">
                <label class="text-[9px] text-zinc-400 font-bold uppercase">Tulis Ulasan Masukan</label>
                <textarea id="review-text-input" rows="3" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 text-xs p-2.5 rounded-xl text-zinc-800 dark:text-zinc-200 focus:outline-none focus:border-gold" placeholder="Contoh: Sepatu sangat nyaman, material kokoh, jahitan rapi!"></textarea>
            </div>
            <div class="flex gap-2 pt-1">
                <button onclick="closeReviewModal()" class="flex-1 bg-zinc-100 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 text-zinc-600 dark:text-zinc-400 text-xs font-bold py-2.5 rounded-xl">Nanti Saja</button>
                <button onclick="submitProductReview()" class="flex-1 bg-gold text-black text-xs font-black py-2.5 rounded-xl uppercase tracking-wider">Kirim Ulasan</button>
            </div>
        </div>
    </div>

    <!-- KOMPONEN: MODAL POPUP JELAJAH SEMUA ULASAN -->
    <div id="see-all-reviews-modal" class="fixed inset-0 bg-black/80 z-50 flex items-end justify-center hidden max-w-md mx-auto">
        <div class="bg-white dark:bg-zinc-900 w-full h-[80vh] rounded-t-3xl border-t border-zinc-200 dark:border-zinc-800 flex flex-col p-4 space-y-4 shadow-2xl overflow-hidden">
            <div class="flex justify-between items-center border-b border-zinc-100 dark:border-zinc-800 pb-3 flex-shrink-0">
                <div>
                    <h3 class="text-xs font-black uppercase tracking-wider text-zinc-800 dark:text-zinc-200 flex items-center gap-1.5"><i data-lucide="message-circle" class="w-4 h-4 text-gold"></i> Semua Penilaian Pembeli</h3>
                    <p id="explorer-modal-subtitle" class="text-[10px] text-zinc-400 mt-0.5">Total ulasan terverifikasi</p>
                </div>
                <button onclick="closeAllReviewsModal()" class="bg-zinc-100 dark:bg-zinc-950 p-2 rounded-full border border-zinc-200 dark:border-zinc-800 text-zinc-500"><i data-lucide="x" class="w-4 h-4"></i></button>
            </div>
            <div id="explorer-reviews-scroll-container" class="flex-1 overflow-y-auto hide-scrollbar divide-y divide-zinc-100 dark:divide-zinc-800 pr-1"></div>
        </div>
    </div>

    <!-- LAYAR UTAMA: ANIMASI SPLASH LOADING SCREEN -->
    <div id="loading-screen" class="fixed inset-0 bg-black z-50 flex flex-col items-center justify-center max-w-md mx-auto transition-all duration-500">
        <div class="text-center space-y-3 animate-pulse">
            <div class="w-20 h-20 rounded-full border-2 border-gold flex items-center justify-center mx-auto shadow-lg shadow-gold/20">
                <span class="text-gold font-serif text-3xl italic font-bold">V</span>
            </div>
            <div class="space-y-0.5">
                <h1 class="text-3xl font-light tracking-[0.3em] serif text-white">VIRELLO</h1>
                <p class="text-[9px] text-gold tracking-[0.15em] uppercase font-medium"></p>
            </div>
        </div>
    </div>

    <!-- GERBANG AUTENTIKASI: PORTAL LOGIN MINIMALIS GAYA PREMIUM -->
    <div id="auth-portal" class="fixed inset-0 bg-white dark:bg-zinc-950 z-40 p-6 flex flex-col justify-between max-w-md mx-auto overflow-y-auto hide-scrollbar">
        <div class="flex items-center justify-between pt-2">
            <button class="text-zinc-400"><i data-lucide="arrow-left" class="w-5 h-5"></i></button>
            <span class="text-xs text-zinc-500 font-medium">Bantuan</span>
        </div>
        <div class="space-y-8 my-auto w-full px-2">
            <div class="text-center space-y-1">
                <h1 class="text-3xl font-light tracking-[0.2em] serif text-zinc-900 dark:text-white font-bold">VIRELLO</h1>
                <p class="text-[10px] text-gold-dark uppercase tracking-widest font-medium">Signature Shoes Collection</p>
            </div>
            <div class="space-y-4">
                <div class="relative border-b border-zinc-200 dark:border-zinc-800 py-2.5 flex items-center gap-2">
                    <i data-lucide="user" class="w-4 h-4 text-zinc-400"></i>
                    <input type="text" id="auth-username" value="" class="w-full bg-transparent text-xs text-zinc-800 dark:text-white focus:outline-none placeholder-zinc-400" placeholder="No. Handphone/Email/Username">
                </div>
                <div class="relative border-b border-zinc-200 dark:border-zinc-800 py-2.5 flex items-center gap-2">
                    <i data-lucide="lock" class="w-4 h-4 text-zinc-400"></i>
                    <input type="password" id="auth-userid" value="VR-2026-0221" class="w-full bg-transparent text-xs text-zinc-800 dark:text-white font-mono focus:outline-none placeholder-zinc-400" placeholder="Password / Secure User ID">
                </div>
                <button onclick="validateCredentialLogin()" class="w-full bg-gold hover:bg-gold-dark text-black font-bold py-3 rounded-lg text-xs uppercase tracking-wider transition-all shadow-sm mt-3">Log In</button>
            </div>
            <div class="relative flex py-2 items-center">
                <div class="flex-grow border-t border-zinc-200 dark:border-zinc-900"></div>
                <span class="flex-shrink mx-3 text-zinc-400 text-[10px] uppercase font-medium tracking-wider">ATAU</span>
                <div class="flex-grow border-t border-zinc-200 dark:border-zinc-900"></div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <button onclick="requestPhoneOTP()" class="border border-zinc-200 dark:border-zinc-800 rounded-lg p-2.5 flex items-center justify-center gap-2 text-xs font-semibold hover:bg-zinc-50 dark:hover:bg-zinc-900">
                    <i data-lucide="phone" class="w-4 h-4 text-gold"></i> SMS OTP
                </button>
                <button onclick="bypassAuthentication('', 'Google ID Master')" class="border border-zinc-200 dark:border-zinc-800 rounded-lg p-2.5 flex items-center justify-center gap-2 text-xs font-semibold hover:bg-zinc-50 dark:hover:bg-zinc-900">
                    <i data-lucide="chrome" class="w-4 h-4 text-red-500"></i> Google
                </button>
            </div>
        </div>
        <div class="text-center text-[10px] text-zinc-400 pb-2">Belum punya akun? <span class="text-gold font-bold ml-1 cursor-pointer">Daftar</span></div>
    </div>

    <!-- MAIN INTERACTIVE INTERFACE HUB -->
    <div id="main-dashboard" class="hidden">
        <!-- HEADER UTAMA -->
        <header id="dashboard-header" class="sticky top-0 z-30 bg-white/95 dark:bg-[#030303]/95 backdrop-blur-md border-b border-zinc-100 dark:border-zinc-900 p-4 space-y-3 shadow-sm transition-all">
            <div class="flex items-center justify-between gap-3">
                <div class="flex-1 relative">
                    <input type="text" id="search-input" oninput="handleSearch()" placeholder="Cari Adidas, Nike, Vans, Puma..." class="w-full bg-zinc-100 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl pl-9 pr-4 py-2 text-xs focus:outline-none text-zinc-800 dark:text-zinc-200 focus:border-gold font-medium">
                    <i data-lucide="search" class="w-4 h-4 text-zinc-400 absolute left-3 top-2.5"></i>
                </div>
                <div class="flex gap-2.5 text-zinc-500 dark:text-zinc-400 items-center">
                    <button onclick="toggleThemeMode()" class="p-1 hover:text-gold transition-colors">
                        <i data-lucide="sun" id="theme-icon-sun" class="w-5 h-5 hidden"></i>
                        <i data-lucide="moon" id="theme-icon-moon" class="w-5 h-5"></i>
                    </button>
                    <button onclick="changeTab('cart')" class="relative p-1 hover:text-gold transition-colors">
                        <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                        <span id="cart-badge" class="absolute -top-1 -right-1.5 bg-red-500 text-white text-[8px] font-bold px-1 rounded-full hidden">0</span>
                    </button>
                </div>
            </div>
            <div class="flex items-center text-[11px]">
                <div class="flex items-center gap-1 text-zinc-400">
                    <i data-lucide="map-pin" class="w-3.5 h-3.5 text-red-500"></i>
                    <span>Dikirim ke <strong class="text-zinc-800 dark:text-zinc-200 font-bold">Depok, West Java</strong></span>
                </div>
            </div>
        </header>

        <main class="p-0">
            <!-- ARSIP PANDANGAN: TAB BERANDA (HOME) -->
            <div id="tab-home" class="tab-view space-y-5 p-4">
                <div class="w-full bg-gradient-to-br from-[#9e7f43] via-[#dfba73] to-[#7a5f2c] text-black p-4 rounded-xl relative overflow-hidden shadow-xl">
                    <span class="text-[8px] bg-black text-gold font-black px-2 py-0.5 rounded-md uppercase">Kejar Diskon Gold</span>
                    <h3 class="text-base font-extrabold mt-1 uppercase tracking-tight">Virello Gold Member Day</h3>
                    <p class="text-[11px] opacity-90 leading-tight">Potongan Harga Komplementer + Bebas Ongkir Prioritas Seluruh Indonesia</p>
                </div>

                <!-- FITUR KATEGORI 1: STATUS KHUSUS DROPS -->
                <div class="space-y-1.5">
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-zinc-400 flex items-center gap-1"><i data-lucide="tags" class="w-3.5 h-3.5 text-gold"></i> Kategori Tren Drops</h4>
                    <div class="flex gap-1.5 overflow-x-auto hide-scrollbar py-0.5">
                        <button onclick="filterTrendingStatus('ALL', this)" class="trend-tag-btn bg-gold text-black text-[9px] font-extrabold px-3 py-1.5 rounded-lg transition-all whitespace-nowrap">🔥 ALL DROPS</button>
                        <button onclick="filterTrendingStatus('NEW ARRIVAL', this)" class="trend-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap">✨ NEW ARRIVAL</button>
                        <button onclick="filterTrendingStatus('BEST SELLER', this)" class="trend-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap">👑 BEST SELLER</button>
                        <button onclick="filterTrendingStatus('LIMITED EDITION', this)" class="trend-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap">⏳ LIMITED EDITION</button>
                        <button onclick="filterTrendingStatus('FLASH SALE', this)" class="trend-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap">⚡ FLASH SALE</button>
                        <button onclick="filterTrendingStatus('PREMIUM COLLECTION', this)" class="trend-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap">💎 PREMIUM</button>
                    </div>
                </div>

                <!-- FITUR KATEGORI 2: MODEL AKTIVITAS -->
                <div class="space-y-1.5">
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-zinc-400 flex items-center gap-1"><i data-lucide="layers" class="w-3.5 h-3.5 text-gold"></i> Model Aktivitas</h4>
                    <div class="flex gap-1.5 overflow-x-auto hide-scrollbar py-0.5">
                        <button onclick="filterActivityStyle('ALL', this)" class="activity-tag-btn bg-zinc-800 text-white dark:bg-white dark:text-black text-[9px] font-extrabold px-3.5 py-1.5 rounded-lg transition-all whitespace-nowrap">SEMUA MODEL</button>
                        <button onclick="filterActivityStyle('CASUAL', this)" class="activity-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3.5 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap">👟 CASUAL</button>
                        <button onclick="filterActivityStyle('SPORT', this)" class="activity-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3.5 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap">🏃 SPORT</button>
                        <button onclick="filterActivityStyle('FORMAL', this)" class="activity-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3.5 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap">💼 FORMAL</button>
                        <button onclick="filterActivityStyle('SCHOOL', this)" class="activity-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3.5 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap">✏️ SCHOOL</button>
                    </div>
                </div>

                <div class="space-y-3">
                    <div class="flex items-center justify-between">
                        <h4 class="text-xs font-extrabold uppercase tracking-wide text-gold flex items-center gap-1"><i data-lucide="zap" class="w-3.5 h-3.5 fill-current"></i> Rilisan Koleksi Eksklusif</h4>
                        <span id="total-product-lbl" class="text-[10px] text-zinc-400 font-medium">Memuat...</span>
                    </div>
                    <div class="grid grid-cols-2 gap-3" id="store-catalog"></div>
                </div>
            </div>

            <!-- ARSIP PANDANGAN: TAB KERANJANG BELANJA (CART) -->
            <div id="tab-cart" class="tab-view hidden space-y-4 p-4">
                <h3 class="text-sm font-bold text-zinc-800 dark:text-zinc-200">Keranjang Belanja</h3>
                <div id="cart-items-list" class="space-y-3"></div>
                <div class="border-t border-zinc-200 dark:border-zinc-900 pt-3 space-y-2">
                    <div class="flex justify-between items-baseline pt-2">
                        <span class="text-sm font-bold text-zinc-800 dark:text-zinc-200">Total Tagihan Belanja:</span>
                        <span id="cart-total-price" class="text-gold font-extrabold text-xl font-mono">Rp 0</span>
                    </div>
                </div>
                <button onclick="processInternalCheckout()" class="w-full bg-gold text-black font-bold py-3.5 rounded-xl text-xs uppercase tracking-wider shadow-md">Selesaikan Pembayaran</button>
            </div>

            <!-- ================= REVISI UTAMA: TAB LACAK PAKET SUPER SIMPEL & LUXURY ================= -->
            <div id="tab-tracking" class="tab-view hidden p-4 space-y-4 bg-zinc-50 dark:bg-zinc-950 min-h-[80vh]">
                <!-- Kartu Status Ringkas Sederhana -->
                <div class="relative overflow-hidden bg-white/95 dark:bg-zinc-900/90 border border-zinc-200/60 dark:border-zinc-800/80 p-4 rounded-2xl shadow-sm flex justify-between items-center">
                    <div class="absolute inset-0 bg-gradient-to-br from-gold/20 via-transparent to-transparent pointer-events-none"></div>
                    <div class="relative flex items-center gap-3">
                        <div class="bg-gold/10 p-2.5 rounded-xl text-gold">
                            <i data-lucide="package" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <span class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider block">Tracking Luxury</span>
                            <h3 id="quick-status-badge" class="text-xs font-black text-zinc-800 dark:text-zinc-100 mt-0.5">DALAM PERJALANAN</h3>
                        </div>
                    </div>
                    <div class="relative text-right">
                        <span class="text-[10px] text-zinc-400 block font-medium">J&T Prioritas</span>
                        <span id="quick-resi" class="text-[11px] font-mono font-extrabold text-gold mt-0.5 block">VR-77491026</span>
                        <div class="text-[9px] text-zinc-500 dark:text-zinc-400 mt-1">Est. 1–2 hari kerja</div>
                    </div>
                </div>

                <!-- Timeline step by step (vertikal) -->
                <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800/80 p-4 rounded-2xl shadow-sm space-y-3">
                    <div class="flex items-center justify-between">
                        <h4 class="text-xs font-extrabold uppercase tracking-wider text-zinc-800 dark:text-zinc-200 flex items-center gap-1.5">
                            <i data-lucide="list-check" class="w-4 h-4 text-gold"></i>
                            Timeline Pesanan
                        </h4>
                        <span class="text-[10px] text-zinc-400 font-medium">{TRACKING_STEP_TEXT}</span>
                    </div>

                    <div class="relative pl-6">
                        <div class="absolute left-2.5 top-0 bottom-0 w-0.5 bg-zinc-200 dark:bg-zinc-800 rounded-full"></div>

                        <div class="space-y-4" id="tracking-timeline-steps">
                            <!-- diisi via JS -->
                        </div>
                    </div>
                </div>

                <!-- Live Mini Progress Tracker Bar -->
                <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800/80 p-4 rounded-2xl shadow-sm space-y-3">
                    <div class="flex justify-between items-center text-[10px] font-bold uppercase tracking-wider text-zinc-400">
                        <span class="text-gold" id="lbl-pos-1">Diproses</span>
                        <span class="text-gold" id="lbl-pos-2">Kurir</span>
                        <span id="lbl-pos-3">Tiba</span>
                    </div>
                    <div class="w-full bg-zinc-200 dark:bg-zinc-800 h-1.5 rounded-full overflow-hidden">
                        <div id="simple-progress-bar" class="bg-gold h-full w-2/3 transition-all duration-700"></div>
                    </div>
                    <p id="simple-tracking-desc" class="text-[11px] text-zinc-500 dark:text-zinc-400 leading-relaxed pt-1 flex items-center gap-1.5">
                        <i data-lucide="map-pin" class="w-3.5 h-3.5 text-red-500 flex-shrink-0"></i>
                        <span>Paket berada di <strong class="text-zinc-800 dark:text-zinc-200 font-bold">Pusat Transit Depok</strong>. Menuju lokasi Anda.</span>
                    </p>
                </div>

                <!-- Footer Tracking ala Shopee (lokasi + tombol aksi) -->
                <div class="bg-white/70 dark:bg-zinc-950/60 border border-zinc-200/70 dark:border-zinc-800/70 rounded-2xl p-3 shadow-sm">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex items-start gap-2">
                            <div class="bg-red-500/10 p-2.5 rounded-xl text-red-500">
                                <i data-lucide="map-pin" class="w-4 h-4"></i>
                            </div>
                            <div>
                                <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider">Lokasi Terakhir</div>
                                <div class="text-xs font-black text-zinc-800 dark:text-zinc-100 mt-0.5" id="last-location-title">Pusat Transit Depok</div>
                                <div class="text-[9px] text-zinc-500 dark:text-zinc-400 mt-0.5" id="last-location-sub">Diperbarui beberapa saat lalu</div>
                            </div>
                        </div>
                        <div class="text-right">
                            <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider">Status</div>
                            <div class="text-[11px] font-extrabold text-gold mt-0.5" id="last-status-flag">{STATUS}</div>
                        </div>
                    </div>
                    <div id="action-delivery-container" class="hidden mt-3">
                        <button onclick="triggerOrderArrived()" class="w-full bg-gold hover:bg-gold-dark text-black font-black py-3 rounded-xl text-xs uppercase tracking-wider shadow-md transition-all">
                            Konfirmasi Pesanan Diterima
                        </button>
                    </div>
                </div>

                <!-- Kontainer Tersembunyi untuk integrasi data lama -->
                <div id="detailed-manifest-stepper" class="hidden"></div>
                <div id="quick-courier" class="hidden"></div>
            </div>

            <!-- ARSIP PANDANGAN: TAB AKUN -->
            <div id="tab-profile" class="tab-view hidden bg-zinc-100 dark:bg-zinc-950 min-h-[85vh]">
                <!-- Header Akun Bernuansa Hitam Emas Mewah -->
                <div class="bg-gradient-to-r from-zinc-900 via-[#1a1a1a] to-zinc-950 text-white p-5 pt-6 flex items-center justify-between border-b border-zinc-800">
                    <div class="flex items-center gap-3.5">
                        <div class="w-14 h-14 rounded-full bg-gold/10 border-2 border-gold/30 flex items-center justify-center font-bold text-2xl shadow-md text-gold">😆</div>
                        <div class="space-y-1">
                            <h3 id="profile-display-name" class="text-sm font-black tracking-wide text-zinc-100">M. Riskil Mubarok</h3>
                            <div class="flex items-center gap-1">
                                <span class="text-[9px] bg-gold/10 text-gold px-2 py-0.5 rounded-full font-bold uppercase tracking-wider border border-gold/20">Virello Member Gold</span>
                            </div>
                        </div>
