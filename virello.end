                </div>

                <!-- Info Finansial Brankas VirPay -->
                <div class="bg-white dark:bg-zinc-900 border-y border-zinc-200 dark:border-zinc-800 mt-2 grid grid-cols-2 divide-x divide-zinc-100 dark:divide-zinc-800 p-3 text-center">
                    <div class="space-y-0.5 flex flex-col items-center justify-center cursor-pointer" onclick="executeTopUp()">
                        <div class="flex items-center gap-1 text-zinc-800 dark:text-zinc-200">
                            <i data-lucide="coins" class="w-4 h-4 text-gold fill-current"></i>
                            <span id="profile-wallet-lbl" class="font-mono text-xs font-black">Rp 5.000.000</span>
                        </div>
