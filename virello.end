                <!-- Panel Status Pesanan Saku -->
                <div class="bg-white dark:bg-zinc-900 border-b border-zinc-200 dark:border-zinc-800 p-3 mt-0">
                    <div class="flex justify-between items-center border-b border-zinc-100 dark:border-zinc-800/60 pb-2 text-xs">
                        <span class="font-bold text-zinc-800 dark:text-zinc-200 flex items-center gap-1.5"><i data-lucide="clipboard-list" class="w-4 h-4 text-zinc-400"></i> Pesanan Saya</span>
                        <span class="text-zinc-400 text-[11px] cursor-pointer flex items-center">Lihat Riwayat <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i></span>
