        </main>

        <!-- NAVIGASI BOTTOM BAR MENYATU -->
        <nav class="fixed bottom-0 left-0 right-0 max-w-md mx-auto bg-white dark:bg-[#030303] border-t border-zinc-200 dark:border-zinc-950 py-2.5 px-1 flex justify-between items-center z-30 shadow-2xl transition-all">
            <button id="nav-home" onclick="changeTab('home')" class="flex-1 flex flex-col items-center gap-0.5 text-gold"><i data-lucide="home" class="w-4.5 h-4.5"></i><span class="text-[9px] font-bold">Rekomendasi</span></button>
            <button id="nav-cart" onclick="changeTab('cart')" class="flex-1 flex flex-col items-center gap-0.5 text-zinc-400"><i data-lucide="shopping-bag" class="w-4.5 h-4.5"></i><span class="text-[9px]">Keranjang</span></button>
            <button id="nav-tracking" onclick="changeTab('tracking')" class="flex-1 flex flex-col items-center gap-0.5 text-zinc-400"><i data-lucide="truck" class="w-4.5 h-4.5"></i><span class="text-[9px]">Lacak</span></button>
            <button id="nav-profile" onclick="changeTab('profile')" class="flex-1 flex flex-col items-center gap-0.5 text-zinc-400"><i data-lucide="user" class="w-4.5 h-4.5"></i><span class="text-[9px]">Saya</span></button>
        </nav>
    </div>

    <!-- LOGIKA SKRIP JAVASCRIPT MASTER HUB -->
    <script>
        // EKSPANSI KATALOG BESAR 12 ITEM DENGAN VARIASI BRAND DAN ULASAN PEMBELI MELIMPAH
        const products = [
            { id: 1, name: "Louis Vuitton Monogram Canvas Sneakers in White Leather", price: 24642324, img: "https://cdn1.jolicloset.com/img4/detail4b/2024/02/1199445-1/louis-vuitton-monogram-canvas-sneakers-in-white-leather.jpg", location: "Jakarta Pusat", sold: "4.8rb terjual", trend: "LIMITED EDITION", category: "FORMAL", rating: 4.9, reviews: [{ name: "b*****s", rating: 5.0, date: "01-07-2026", text: "awesome" }, { name: "r*****m", rating: 5, date: "15-06-2026", text: "Warna ikonik sepanjang masa, jahitan mulus!" }] },
            { id: 2, name: "Nike Shox TL Riccardo Tisci Black", price: 3259000, img: "https://image.807garage.com/content/uploads/2026/4/nike-shox-tl-riccardo-tisci-black-2.jpg", location: "Bandung", sold: "1.2rb terjual", trend: "FLASH SALE", category: "CASUAL", rating: 4.8, reviews: [{ name: "s*****w", rating: 5.0, date: "02-07-2026", text: "Ringan banget buat lari maraton, beneran mantap!" }] },
            { id: 3, name: "Nike Air Force 1 '07 Triple White Classic", price: 1549000, img: "https://www.static-src.com/wcsstore/Indraprastha/images/catalog/full//90/MTA-52152327/nike_nike_air_force_1_-07_triple_white_-2021-_full01_kzab3nip.jpg", location: "Depok", sold: "8.9rb terjual", trend: "NEW ARRIVAL", category: "SCHOOL", rating: 4.6, reviews: [{ name: "d*****a", rating: 4.0, date: "03-07-2026", text: "Sepatu putih wajib buat anak sekolahan." }] },
            { id: 4, name: "Adidas Samba OG Core Leather Shadow Black", price: 1999000, img: "https://image.807garage.com/content/uploads/2024/6/adidas-samba-og-black-white-gum-6.jpg", location: "Tangerang", sold: "2.5rb terjual", trend: "RESTOCK", category: "CASUAL", rating: 4.7, reviews: [{ name: "h*****n", rating: 4.0, date: "29-06-2026", text: "Desain ramping khas Samba. Cocok buat skena." }] },
            { id: 5, name: "Adidas Ultraboost Light Carbon Triple Black", price: 2999000, img: "https://images.stockx.com/images/adidas-Ultra-Boost-Light-Triple-Black-Product.jpg?fit=fill&bg=FFFFFF&w=700&h=500&fm=webp&auto=compress&q=90&dpr=2&trim=color&updated_at=1738193358", location: "Surabaya", sold: "3.4rb terjual", trend: "PREMIUM COLLECTION", category: "SPORT", rating: 4.9, reviews: [{ name: "a*****m", rating: 5, date: "01-02-2026", text: "Bagus dipakai untuk olahraga" }] },
            { id: 6, name: "Puma Suede Classic XXI Heritage Navy Blue", price: 1399000, img: "https://images.unsplash.com/photo-1608231387042-66d1773070a5?auto=format&fit=crop&w=400&q=80", location: "Semarang", sold: "831 terjual", trend: "NEW ARRIVAL", category: "CASUAL", rating: 4.8, reviews: [{ name: "f****n", rating: 4.7, date: "02-07-2026", text: "sepatunya sudah sampai dan bahannya berkualitas" }] },
            { id: 7, name: "Onitsuka Tiger MEXICO 66 NM", price: 3199000, img: "https://images.asics.com/is/image/asics/1183C319_002_SR_RT_GLB?qlt=100&wid=1024&hei=768&bgc=255,255,255&resMode=bisharp", location: "Jakarta Selatan", sold: "411 terjual", trend: "CASUAL", category: "SPORT", rating: 4.9, reviews: [{ name: "cok", rating: 4.3, date: "21-09-2026", text: "Sangat nyaman" }] },
            { id: 8, name: "Converse Chuck Taylor All Star 70s High", price: 1099000, img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRSdZrlq7qWCFpgMBEHo9ZSrTkcvnOFqTLfhiBRoa6U7YSeZNzowXEmpYU&s=10", location: "Yogyakarta", sold: "6.2rb terjual", trend: "RESTOCK", category: "SCHOOL", rating: 4.7, reviews: [{ name: "a*****p", rating: 5.0, date: "01-07-2026", text: "Sol dalemnya empuk tebel khas Converse 70s." }] },
            { id: 9, name: "Vans Old Skool Core Classic Black White", price: 1149000, img: "https://images.tokopedia.net/img/cache/700/product-1/2020/2/3/520644775/520644775_393e630b-17cd-404f-9273-2b286744bece_1080_1080.jpg.webp", location: "Malang", sold: "5.5rb terjual", trend: "BEST SELLER", category: "SCHOOL", rating: 4.6, reviews: [{ name: "e*****r", rating: 5.0, date: "01-09-2026", text: "cocok dipakai untuk dipakai sehari hari " }] },
            { id: 10, name: "Vans Vault Slip-On LX Checkerboard Premium", price: 1699000, img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQUCmnFinYfCCkyciIgYf38nnTrCK6hRSFVZvu3Lw61lISQGuhUS-Nb6gjh&s=10", location: "Solo", sold: "740 terjual", trend: "LIMITED EDITION", category: "CASUAL", rating: 4.8, reviews: [{ name: "d****an", rating: 4.7, date: "21-03-2023", text: "skenaa abiezzzzzzzz." }] },
            { id: 11, name: "New Balance 550 White Grey Ateliers", price: 2199000, img: "https://image-cdn.hypb.st/https%3A%2F%2Fhypebeast.com%2Fimage%2F2022%2F07%2Fnew-balance-550-white-grey-BB550WTG-tw.jpg?w=960&cbr=1&q=90&fit=max", location: "Jakarta Barat", sold: "942 terjual", trend: "NEW ARRIVAL", category: "CASUAL", rating: 5.0, reviews: [{ name: "Y*****m", rating: 4.8, date: "02-02-2026", text: "Material premium dan tahan lama." }] },
            { id: 12, name: "Cloud 6 Geo Waterproof", price: 5400000, img: "https://images.ctfassets.net/hnk2vsx53n6l/2wHDWmzb84XYtW1B4duxXn/1a51341550da535b572cb57cbb9ae4e8/c6af59ac0ea1b08332b0d4ec4c3d5d386bc4c7a3.png?w=4000&h=4000&fm=avif&f=center&fit=fill&q=80", location: "Jakarta Pusat", sold: "120 terjual", trend: "BEST SELLER", category: "SPORT", rating: 5.0, reviews: [{ name: "v*****i", rating: 5.0, date: "24-06-2026", text: "Sangat nyaman untuk digunakan" }] },
            { id: 13, name: "Puma Speedcat OG Sneakers", price: 3999000, img: "https://images.puma.com/image/upload/f_auto,q_auto,b_rgb:fafafa,w_2000,h_2000/global/398846/01/sv01/fnd/IDN/fmt/png/Sepatu-Speedcat-OG-Unisex-Sneakers", location: "jakarta utara", sold: "100 terjual", trend: "PREMIUM COLLECTION", category: "FORMAL", rating: 4.9, reviews: [{ name: "ibin", rating: 4.5, date: "12-07-2023", text: "lwk cute for my outfit" }] },
            { id: 14, name: "Reebok Unisex Classic Leather 2400 Trainers, ", price: 1900000, img: "https://down-id.img.susercontent.com/file/id-11134207-8224t-mie9579nflza9b", location: "memek", sold: "3.1rb terjual", trend: "NEW ARRIVAL", category: "CASUAL", rating: 4.7, reviews: [{ name: "om f***l", rating: 4.9, date: "19-02-2026", text: "bahannya bagus dan barangnya mulus" }] }
        ];

        let cart = []; let userWallet = 5000000; let completedOrders = []; 
        let activeTrendingFilter = "ALL"; let activeActivityFilter = "ALL";
        let activeReviewingProductID = 1; let temporaryReviewRating = 5;

        window.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => { document.getElementById('loading-screen').classList.add('opacity-0', 'pointer-events-none'); }, 1200);
            renderStoreCatalog();
            // Inisialisasi awal simulasi tracking ringkas default
            setupSimpleTracking(false);
        });

        // FUNGSI BARU: PENGATUR ALUR LACAK SIMPEL & LUXURY
        // SISTEM PELACAKAN PAKET (SIMULASI) - single source of truth
        const trackingState = {
            step: 0, // 0..3
            resi: "VR-77491026",
            steps: [
                {
                    status: "DIPROSES",
                    badgePulse: true,
                    progress: 0.25,
                    pos1: "text-gold font-bold",
                    pos2: "text-zinc-400",
                    pos3: "text-zinc-400",
                    desc: `<i data-lucide="package" class="w-4 h-4 text-red-500 flex-shrink-0"></i><span>Paket sedang dipersiapkan oleh gudang. Menuju kurir.</span>`,
                    actionVisible: false
                },
                {
                    status: "DIKURIRKAN",
                    badgePulse: true,
                    progress: 0.5,
                    pos1: "text-gold font-bold",
                    pos2: "text-gold font-black animate-pulse",
                    pos3: "text-zinc-400",
                    desc: `<i data-lucide="map-pin" class="w-4 h-4 text-red-500 flex-shrink-0"></i><span>Paket berada di <strong class="text-zinc-800 dark:text-zinc-200">Pusat Transit Depok</strong>. Menuju rumah Anda.</span>`,
                    actionVisible: true
                },
                {
                    status: "MENDEKATI TUJUAN",
                    badgePulse: false,
                    progress: 0.75,
                    pos1: "text-gold font-bold",
                    pos2: "text-gold font-bold",
                    pos3: "text-zinc-400",
                    desc: `<i data-lucide="truck" class="w-4 h-4 text-amber-500 flex-shrink-0"></i><span>Kurir sedang melaju menuju alamat pengantaran.</span>`,
                    actionVisible: true
                },
                {
                    status: "SELESAI DITERIMA",
                    badgePulse: false,
                    progress: 1,
                    pos1: "text-gold font-bold",
                    pos2: "text-gold font-bold",
                    pos3: "text-gold font-black",
                    desc: `<i data-lucide="check-circle" class="w-4 h-4 text-emerald-500 flex-shrink-0"></i><span>Paket sukses diserahkan ke <strong class="text-zinc-800 dark:text-zinc-200">M. Riskil Mubarok</strong> (Depok).</span>`,
                    actionVisible: false
                }
            ]
        };

        function renderTrackingTimeline() {
            const container = document.getElementById('tracking-timeline-steps');
            if (!container) return;

            const stepIndex = trackingState.step;

            const stepsUI = [
                { label: 'DIPROSES', hint: 'Paket sedang dipersiapkan oleh gudang. Menuju kurir.', icon: 'package' },
                { label: 'DIKURIRKAN', hint: 'Paket berada di Pusat Transit Depok. Menuju rumah Anda.', icon: 'map-pin' },
                { label: 'MENDEKATI TUJUAN', hint: 'Kurir sedang melaju menuju alamat pengantaran.', icon: 'truck' },
                { label: 'SELESAI DITERIMA', hint: 'Paket sukses diserahkan ke M. Riskil Mubarok (Depok).', icon: 'check-circle' },
            ];

            container.innerHTML = stepsUI.map((s, idx) => {
                const reached = idx <= stepIndex;
                const circleCls = reached ? 'bg-gold text-black' : 'bg-zinc-200 dark:bg-zinc-800 text-zinc-500';
                const textCls = reached ? 'text-zinc-900 dark:text-zinc-100' : 'text-zinc-500 dark:text-zinc-400';

                return `
                    <div class="flex items-start gap-3">
                        <div class="h-6 w-6 rounded-full ${circleCls} flex items-center justify-center text-[10px] font-bold flex-shrink-0">
                            ${idx + 1}
                        </div>
                        <div class="min-w-0">
                            <div class="flex items-center gap-2">
                                <i data-lucide="${s.icon}" class="w-4 h-4 ${reached ? 'text-gold' : 'text-zinc-400'} flex-shrink-0"></i>
                                <div class="${textCls} text-[11px] font-extrabold uppercase tracking-wider">${s.label}</div>
                            </div>
                            <p class="${textCls} text-[10px] mt-1 leading-relaxed">${s.hint}</p>
                        </div>
                    </div>
                `;
            }).join('');

            const badge = document.querySelector('#tab-tracking [text], #tab-tracking .tracking-timeline-badge');
            lucide.createIcons();
        }

        function setupSimpleTracking(isArrived = false) {
            // compat: isArrived=true langsung set step terakhir
            if (isArrived) trackingState.step = 3;
            else if (trackingState.step < 1) trackingState.step = 1; // default to "dalam perjalanan"

            const s = trackingState.steps[trackingState.step];

            const statusBadge = document.getElementById('quick-status-badge');
            const progressBar = document.getElementById('simple-progress-bar');
            const trackDesc = document.getElementById('simple-tracking-desc');
            const actionContainer = document.getElementById('action-delivery-container');
            const lblPos1 = document.getElementById('lbl-pos-1');
            const lblPos2 = document.getElementById('lbl-pos-2');
            const lblPos3 = document.getElementById('lbl-pos-3');

            statusBadge.innerText = s.status;
            const lastStatusFlag = document.getElementById('last-status-flag');
            if (lastStatusFlag) lastStatusFlag.innerText = s.status;
            const lastLocationTitle = document.getElementById('last-location-title');
            if (lastLocationTitle) {
                if (trackingState.step === 0) lastLocationTitle.innerText = "Gudang Virello - JakPusat";
                if (trackingState.step === 1) lastLocationTitle.innerText = "Pusat Transit Depok";
                if (trackingState.step === 2) lastLocationTitle.innerText = "Menuju Alamat Pengantaran";
                if (trackingState.step === 3) lastLocationTitle.innerText = "Terverifikasi di Depok";
            }
            progressBar.style.width = Math.round(s.progress * 10000) / 100 + "%";

            lblPos1.className = s.pos1;
            lblPos2.className = s.pos2;
            lblPos3.className = s.pos3;

            trackDesc.innerHTML = s.desc;

            // aksi setelah minimal step>=1
            if (s.actionVisible) actionContainer.classList.remove('hidden');
            else actionContainer.classList.add('hidden');

            // resi
            const quickResi = document.getElementById('quick-resi');
            if (quickResi) quickResi.innerText = trackingState.resi;

            // Render timeline step-by-step
            renderTrackingTimeline();

            lucide.createIcons();
        }


        function advanceTrackingStep() {
            if (trackingState.step < 3) {
                trackingState.step++;
                setupSimpleTracking(trackingState.step === 3);
            }
        }

        function filterTrendingStatus(status, element) {
            activeTrendingFilter = status;
            document.querySelectorAll('.trend-tag-btn').forEach(btn => {
                btn.className = "trend-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap";
            });
            if(element) element.className = "trend-tag-btn bg-gold text-black text-[9px] font-extrabold px-3 py-1.5 rounded-lg transition-all whitespace-nowrap";
            renderStoreCatalog();
        }

        function filterActivityStyle(style, element) {
            activeActivityFilter = style;
            document.querySelectorAll('.activity-tag-btn').forEach(btn => {
                btn.className = "activity-tag-btn bg-zinc-100 dark:bg-zinc-950 text-zinc-500 text-[9px] font-bold px-3.5 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-900 transition-all whitespace-nowrap";
            });
            if(element) element.className = "activity-tag-btn bg-zinc-800 text-white dark:bg-white dark:text-black text-[9px] font-extrabold px-3.5 py-1.5 rounded-lg transition-all whitespace-nowrap";
            renderStoreCatalog();
        }

        function toggleThemeMode() {
            const html = document.documentElement;
            if (html.classList.contains('dark')) { html.classList.remove('dark'); } else { html.classList.add('dark'); }
        }

        function validateCredentialLogin() {
            const userField = document.getElementById('auth-username').value.trim();
            bypassAuthentication(userField, "Secure Hub");
        }

        function requestPhoneOTP() { 
            document.getElementById('otp-area').classList.remove('hidden'); 
            fireAndroidPushNotification("SMS OTP Gateway", "Gunakan kode: 210206"); 
        }
        function validateOTP() { bypassAuthentication("Muhammad Riskil Mubarok", "SMS Gateway"); }

        function bypassAuthentication(name, provider) {
            document.getElementById('auth-portal').classList.add('hidden');
            document.getElementById('main-dashboard').classList.remove('hidden');
            document.getElementById('profile-display-name').innerText = name;
            changeTab('home');
        }

        function changeTab(tabName) {
            document.querySelectorAll('.tab-view').forEach(view => view.classList.add('hidden'));
            document.querySelectorAll('nav button').forEach(btn => btn.className = "flex-1 flex flex-col items-center gap-0.5 text-zinc-400");
            
            const targetView = document.getElementById(`tab-${tabName}`) || document.getElementById(`view-${tabName}`);
            if (targetView) targetView.classList.remove('hidden');
            
            const activeNav = document.getElementById(`nav-${tabName}`);
            if (activeNav) activeNav.className = "flex-1 flex flex-col items-center gap-0.5 text-gold font-bold";
            
            const header = document.getElementById('dashboard-header');
            if(tabName === 'profile' || tabName === 'tracking') {
                header.classList.add('hidden');
            } else {
                header.classList.remove('hidden');
            }
            lucide.createIcons();
        }

        function renderStoreCatalog(filteredData = null) {
            const container = document.getElementById('store-catalog');
            let dataToRender = filteredData || products;
            
            if (activeTrendingFilter !== "ALL") dataToRender = dataToRender.filter(p => p.trend === activeTrendingFilter);
            if (activeActivityFilter !== "ALL") dataToRender = dataToRender.filter(p => p.category === activeActivityFilter);

            document.getElementById('total-product-lbl').innerText = `${dataToRender.length} Produk Drop`;

            container.innerHTML = dataToRender.map(item => `
                <div class="bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 p-2 flex flex-col justify-between cursor-pointer rounded-xl hover:shadow-md transition-all relative" onclick="viewProductDetail(${item.id})">
                    <img src="${item.img}" class="object-cover h-28 w-full mb-1.5 rounded-lg shadow">
                    <h4 class="text-[11px] font-medium text-zinc-800 dark:text-zinc-200 line-clamp-2 leading-tight">${item.name}</h4>
                    <div class="flex items-center gap-1 mt-1 text-[10px] text-amber-500 font-bold">
                        <i data-lucide="star" class="w-3 h-3 fill-current"></i>
                        <span>${item.rating.toFixed(1)}</span>
                        <span class="text-zinc-400 font-normal text-[9px]">(${item.reviews.length})</span>
                    </div>
                    <p class="text-gold-dark dark:text-gold font-extrabold text-xs font-mono mt-1">Rp ${item.price.toLocaleString('id-ID')}</p>
                </div>`).join('');
            lucide.createIcons();
        }

        function viewProductDetail(id) {
            const item = products.find(p => p.id === id);
            activeReviewingProductID = item.id;

            document.getElementById('product-detail-content').innerHTML = `
                <img src="${item.img}" class="w-full h-44 object-cover rounded-xl">
                <h2 class="text-sm font-extrabold text-zinc-800 dark:text-zinc-100 mt-1">${item.name}</h2>
                <p class="text-gold dark:text-gold font-extrabold text-sm font-mono mt-1">Rp ${item.price.toLocaleString('id-ID')}</p>
                <button onclick="addItemToCart(${item.id})" class="w-full bg-gold text-black text-xs font-bold py-3 rounded-xl uppercase tracking-wider mt-2">Masukkan Keranjang</button>`;
            
            const reviewsBox = document.getElementById('product-reviews-box');
            if(!item.reviews || item.reviews.length === 0) {
                reviewsBox.innerHTML = `<p class="text-center py-4 text-zinc-400 italic">Belum ada ulasan.</p>`;
            } else {
                reviewsBox.innerHTML = item.reviews.slice(0, 2).map(rev => `
                    <div class="py-2.5 first:pt-0">
                        <span class="font-medium text-zinc-500 text-[11px]">${rev.name}</span>
                        <p class="text-zinc-800 dark:text-zinc-300 mt-1">"${rev.text}"</p>
                    </div>`).join('');
            }
            changeTab('detail');
        }

        function openAllReviewsModal() {
            const product = products.find(p => p.id === activeReviewingProductID);
            if(!product) return;
            document.getElementById('explorer-modal-subtitle').innerText = `Total ${product.reviews.length} ulasan terverifikasi`;
            const scrollContainer = document.getElementById('explorer-reviews-scroll-container');
            
            scrollContainer.innerHTML = product.reviews.map(rev => `
                <div class="py-3.5">
                    <span class="font-bold text-zinc-800 dark:text-zinc-200 text-[11px]">${rev.name}</span>
                    <p class="text-zinc-700 dark:text-zinc-300 mt-1 text-[11px]">"${rev.text}"</p>
                </div>`).join('');
            document.getElementById('see-all-reviews-modal').classList.remove('hidden');
        }

        function closeAllReviewsModal() { document.getElementById('see-all-reviews-modal').classList.add('hidden'); }

        function addItemToCart(id) {
            const targetProd = products.find(p => p.id === id);
            cart.push({ ...targetProd }); updateCartData(); changeTab('cart');
        }

        function updateCartData() {
            const container = document.getElementById('cart-items-list');
            const badge = document.getElementById('cart-badge');
            badge.classList.remove('hidden'); badge.innerText = cart.length;
            
            container.innerHTML = cart.map(item => `
                <div class="p-3 bg-white dark:bg-zinc-950 border text-xs flex gap-3 rounded-xl">
                    <div class="flex-1 min-w-0"><span class="font-bold">${item.name}</span></div>
                </div>`).join('');
            let subtotal = cart.reduce((acc, curr) => acc + curr.price, 0);
            document.getElementById('cart-total-price').innerText = `Rp ${subtotal.toLocaleString('id-ID')}`;
        }

        function processInternalCheckout() {
            if(cart.length === 0) return;
            let subtotal = cart.reduce((acc, curr) => acc + curr.price, 0);
            let generatedResi = "VR-" + Math.floor(10000000 + Math.random() * 90000000);
            
            activeReviewingProductID = cart[0].id;
            document.getElementById('quick-resi').innerText = generatedResi;
            
            // Pasang tracking sederhana status dalam perjalanan
            setupSimpleTracking(false);
                
            cart = []; updateCartData();
            changeTab('tracking');
        }

        function triggerOrderArrived() {
            // Pasang tracking sederhana status selesai diterima
            setupSimpleTracking(true);
                
            document.getElementById('review-modal').classList.remove('hidden');
            setReviewRating(5);
        }

        function setReviewRating(ratingValue) {
            temporaryReviewRating = ratingValue;
            const stars = document.querySelectorAll('.star-btn');
            stars.forEach((star, index) => {
                if (index < ratingValue) { star.className = "star-btn text-amber-500"; } else { star.className = "star-btn text-zinc-300 dark:text-zinc-700"; }
            });
        }

        function closeReviewModal() {
            document.getElementById('review-modal').classList.add('hidden');
            changeTab('home');
        }

        function submitProductReview() {
            const reviewText = document.getElementById('review-text-input').value.trim();
            if(!reviewText) return;
            const product = products.find(p => p.id === activeReviewingProductID);
            if (product) {
                product.reviews.unshift({ name: "m*****k", rating: temporaryReviewRating, date: "04-07-2026", text: reviewText });
            }
            renderStoreCatalog(); closeReviewModal();
        }

        function handleSearch() {
            const query = document.getElementById('search-input').value.toLowerCase();
            const filtered = products.filter(p => p.name.toLowerCase().includes(query));
            renderStoreCatalog(filtered);
        }

        function fireAndroidPushNotification(title, desc) { 
            const banner = document.getElementById('android-push'); 
            document.getElementById('push-title').innerText = title; document.getElementById('push-desc').innerText = desc; 
            banner.classList.remove('-translate-y-44', 'opacity-0'); 
            setTimeout(() => { banner.classList.add('-translate-y-44', 'opacity-0'); }, 3000); 
        }

        function executeTopUp() { 
            userWallet += 1000000; 
            document.getElementById('profile-wallet-lbl').innerText = `Rp ${userWallet.toLocaleString('id-ID')}`; 
            fireAndroidPushNotification("Dompet VirPay Gold", "Isi saldo sukses ditambahkan.");
        }
    </script>
</body>
</html>
