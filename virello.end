                <div class="bg-white dark:bg-zinc-900 border-y border-zinc-200 dark:border-zinc-800 mt-2 divide-y divide-zinc-100 dark:divide-zinc-800 text-xs">
                    <div class="p-3.5 flex justify-between items-center cursor-pointer hover:bg-zinc-50 dark:hover:bg-zinc-950">
                        <div class="flex items-center gap-2.5 text-zinc-700 dark:text-zinc-300"><i data-lucide="award" class="w-4 h-4 text-amber-500"></i><span>Virello Member Privilege</span></div>
                        <i data-lucide="chevron-right" class="w-4 h-4 text-zinc-300"></i>
                    </div>
